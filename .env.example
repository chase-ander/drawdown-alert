# Drawdown fraction (default 0.05 = -5%)
DRAWDOWN_THRESHOLD=0.05

# Yahoo Finance symbol for the index / asset (default ^GSPC)
SYMBOL=^GSPC

# Calendar days roughly bounding history fetch (~5 years default)
LOOKBACK_DAYS=1825

# How many recent trading days to scan for a crossing (handles missed cron runs)
MISSED_RUN_LOOKBACK=3

# Comma-separated recipient emails (required live; optional dry-run unless you want dry-run to send)
ALERT_EMAILS=you@example.com

# Resend API key — required for production; for --dry-run, set with ALERT_EMAILS to send a real test email on alert
RESEND_API_KEY=

# Verified sender in Resend (use onboarding.onboarding@resend.dev only for testing)
RESEND_FROM=onboarding@resend.dev

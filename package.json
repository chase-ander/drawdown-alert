{
  "name": "drawdown-alert",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Stateless cron: email when S&P 500 crosses a drawdown threshold from ATH",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dry-run": "npm run build --silent && node dist/index.js --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "resend": "^6.0.0",
    "yahoo-finance2": "^3.11.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
